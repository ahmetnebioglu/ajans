{
  "name": "ajans-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "clean": "shx rm -rf apps/**/.next packages/**/.next apps/**/.turbo packages/**/.turbo",
    "dev": "npm run clean && turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:seed": "turbo db:seed",
    "start": "turbo start",
    "stop": "taskkill /f /im node.exe 2>nul || exit 0",
    "postinstall": "prisma generate --schema=./packages/db/prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "playwright": "^1.59.1",
    "prettier": "latest",
    "shx": "^0.4.0",
    "turbo": "latest"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "pg": "^8.20.0",
    "prisma": "^7.7.0"
  },
  "overrides": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  }
}
