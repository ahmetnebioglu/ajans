generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  SUPER_ADMIN
  SYSTEM_SUPPORT
  ADMIN
  EXPERT
  CLIENT
  HR_MANAGER
  CUSTOMER
}

enum AppModule {
  DRIVE
  CMS
  HR
  CRM
}

model User {
  id               String          @id @default(cuid())
  name             String?
  email            String?         @unique
  emailVerified    DateTime?
  image            String?
  role             Role            @default(USER)
  tenantId         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  password         String?
  accounts         Account[]
  auditLogs        AuditLog[]
  communicationOptIn Boolean      @default(true)
  workspaceUsers   WorkspaceUser[]
  notifications    Notification[]
  reports          Report[]
  createdWorkspaces Workspace[]     @relation("WorkspaceCreatedBy")
  sessions         Session[]
  workspaces       Workspace[]      @relation("WorkspaceToExpert")
  
  // Okul ERP Relations
  managedClasses       Classroom[]         @relation("TeacherToClass")
  parentLinks          ParentStudent[]     @relation("ParentToLink")
  requestedPermissions PermissionRequest[] @relation("RequestedBy")
  approvedPermissions  PermissionRequest[] @relation("ApprovedBy")

  // CRM Relations
  leadActivities       LeadActivity[]
  leaveRequests        LeaveRequest[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum WorkspaceStatus {
  PROSPECT
  ACTIVE
  PASSIVE
  BLACKLISTED
  VIP
  CHURN_ALARM
}

model Workspace {
  id            String          @id @default(cuid())
  name          String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  address       String?
  taxNumber     String?
  taxOffice     String?
  phone         String?
  createdById   String?
  tenantId      String          @unique @default(cuid())
  
  activeModules AppModule[]     @default([DRIVE, CMS, HR, CRM])

  // CRM & Compliance
  status             WorkspaceStatus @default(PROSPECT)
  communicationOptIn Boolean         @default(true)

  auditLogs     AuditLog[]
  createdBy     User?           @relation("WorkspaceCreatedBy", fields: [createdById], references: [id])
  users         WorkspaceUser[]
  roles         WorkspaceRole[]
  folders       Folder[]
  reports       Report[]
  experts       User[]          @relation("WorkspaceToExpert")

  @@index([tenantId])
}

model WorkspaceRole {
  id          String   @id @default(cuid())
  name        String   // Örn: "İK Yöneticisi", "Sadece Okur"
  workspaceId String
  permissions String[] // Örn: ["HR_READ", "HR_WRITE", "CRM_READ"]
  isDefault   Boolean  @default(false) 
  
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  users       WorkspaceUser[]
  
  @@unique([workspaceId, name])
}

model WorkspaceUser {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  roleId      String?
  createdAt   DateTime @default(now())

  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole?  @relation(fields: [roleId], references: [id])

  @@unique([userId, workspaceId])
}

model Folder {
  id          String   @id @default(cuid())
  name        String
  workspaceId String
  parentId    String?
  tenantId    String   
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent      Folder?    @relation("SubFolders", fields: [parentId], references: [id])
  children    Folder[]   @relation("SubFolders")
  reports     Report[]

  @@index([tenantId])
}

model Report {
  id           String   @id @default(cuid())
  title        String
  fileUrl      String?
  workspaceId  String
  tenantId     String   
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  category     String?  @default("Genel")
  status       String   @default("BEKLEMEDE")
  folderId     String?
  note         String?
  uploadedById String?
  s3Key        String?
  fileName     String?
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folder       Folder?    @relation(fields: [folderId], references: [id])
  uploadedBy   User?      @relation(fields: [uploadedById], references: [id])

  @@index([tenantId])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  details     String?
  ipAddress   String?
  level       String   @default("INFO")
  createdAt   DateTime @default(now())
  workspaceId String?
  tenantId    String   
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  user        User?      @relation(fields: [userId], references: [id])

  @@index([tenantId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  type      String   @default("INFO")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IsgLibrary {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  content     String
  categoryId  String
  attachments Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  category    IsgCategory @relation(fields: [categoryId], references: [id])
  tenantId    String      @default("mercan")

  @@index([tenantId])
}

model IsgCategory {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  createdAt DateTime      @default(now())
  order     Int           @default(0)
  documents IsgDocument[]
  items     IsgLibrary[]
  tenantId  String        @default("mercan")

  @@index([tenantId])
}

model IsgDocument {
  id          String      @id @default(cuid())
  title       String
  isPublished Boolean     @default(false)
  categoryId  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  s3Key       String
  fileType    String?
  category    IsgCategory @relation(fields: [categoryId], references: [id])
  tenantId    String      @default("mercan")

  @@index([tenantId])
}

model Service {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  content        String
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  icon           String?
  isPublished    Boolean  @default(false)
  featuredImage  String?
  seoDescription String?
  seoTitle       String?
  summary        String?
  tenantId       String   @default("mercan")

  @@index([tenantId])
}

model ReferenceSector {
  id         String      @id @default(cuid())
  name       String
  order      Int         @default(0)
  references Reference[]
  tenantId   String      @default("mercan")

  @@index([tenantId])
}

model Reference {
  id        String           @id @default(cuid())
  name      String
  logo      String?
  order     Int              @default(0)
  createdAt DateTime         @default(now())
  sectorId  String?
  sector    ReferenceSector? @relation(fields: [sectorId], references: [id])
  tenantId  String           @default("mercan")

  @@index([tenantId])
}

model ContactMessage {
  id                String   @id @default(cuid())
  name              String
  email             String
  subject           String?
  message           String
  isRead            Boolean  @default(false)
  createdAt         DateTime @default(now())
  isVerified        Boolean  @default(false)
  verificationToken String?  @unique
  tenantId          String   @default("mercan")

  @@index([tenantId])
}

model HomepageSettings {
  id                 String   @id @default(cuid())
  heroTitle          String?
  heroSubtitle       String?
  heroButtonText     String?
  katipProcess       Json?
  naceBannerTitle    String?
  naceBannerSubtitle String?
  updatedAt          DateTime @updatedAt
  mapUrl             String?
  aboutContent       String?
  aboutImage         String?
  aboutTitle         String?
  heroImages         Json?
  tenantId           String   @unique @default("mercan")

  @@index([tenantId])
}

model ReferenceRequest {
  id                String   @id @default(cuid())
  fullName          String
  companyName       String
  email             String
  sector            String
  isRead            Boolean  @default(false)
  createdAt         DateTime @default(now())
  isVerified        Boolean  @default(false)
  verificationToken String?  @unique
  tenantId          String   @default("mercan")

  @@index([tenantId])
}

model BlogCategory {
  id       String     @id @default(cuid())
  name     String
  slug     String     @unique
  posts    BlogPost[]
  tenantId String     @default("mercan")

  @@index([tenantId])
}

model BlogPost {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  content        String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  categoryId     String?
  excerpt        String?
  isPublished    Boolean       @default(false)
  featuredImage  String?
  seoDescription String?
  seoTitle       String?
  category       BlogCategory? @relation(fields: [categoryId], references: [id])
  tenantId       String        @default("mercan")

  @@index([tenantId])
}

model NaceCode {
  id          String @id @default(cuid())
  code        String
  dangerClass String
  description String
  tenantId    String @default("mercan")

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Page {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  content     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  isPublished Boolean       @default(false)
  sections    PageSection[]
  tenantId    String        @default("mercan")

  @@index([tenantId])
}

model PageSection {
  id        String   @id @default(cuid())
  type      String
  content   Json
  order     Int      @default(0)
  pageId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  tenantId  String   @default("mercan")

  @@index([tenantId])
}

model SiteSettings {
  id                 String   @id @default(cuid())
  logo               String?
  title              String?
  email              String?
  phone              String?
  address            String?
  googlePlacesApiKey String?
  googleDriveApiKey  String?
  googleClientId     String?
  googleClientSecret String?
  googleRefreshToken String?
  googleDriveFolderId String?
  resendApiKey       String?
  netgsmUsercode     String?
  netgsmPassword     String?
  iyzicoApiKey       String?
  iyzicoSecretKey    String?
  iyzicoBaseUrl      String?
  updatedAt          DateTime @updatedAt
  tenantId           String   @unique @default("mercan")

  @@index([tenantId])
}

model Newsletter {
  id                String   @id @default(cuid())
  email             String   @unique
  createdAt         DateTime @default(now())
  status            String   @default("PENDING")
  verificationToken String?  @unique
  tenantId          String   @default("mercan")

  @@index([tenantId])
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  status      String   @default("active")
  tenantId    String
  createdAt   DateTime @default(now())
}

model Classroom {
  id        String    @id @default(cuid())
  name      String
  teacherId String
  teacher   User      @relation("TeacherToClass", fields: [teacherId], references: [id])
  students  Student[]
  tenantId  String
  deletedAt DateTime?

  @@index([tenantId])
}

model Student {
  id                 String              @id @default(cuid())
  firstName          String
  lastName           String
  studentNumber      String
  classroomId        String
  classroom          Classroom           @relation(fields: [classroomId], references: [id])
  parentLinks        ParentStudent[]
  permissionRequests PermissionRequest[]
  tenantId           String
  deletedAt          DateTime?

  @@index([tenantId])
}

model ParentStudent {
  id           String    @id @default(cuid())
  parentId     String
  parent       User      @relation("ParentToLink", fields: [parentId], references: [id])
  studentId    String
  student      Student   @relation(fields: [studentId], references: [id])
  relationType String // Anne, Baba, Diğer
  tenantId     String
  deletedAt    DateTime?

  @@index([tenantId])
}

model PermissionRequest {
  id            String    @id @default(cuid())
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id])
  requestedById String
  requestedBy   User      @relation("RequestedBy", fields: [requestedById], references: [id])
  approvedById  String?
  approvedBy    User?     @relation("ApprovedBy", fields: [approvedById], references: [id])
  type          String // ABSENCE, EARLY_LEAVE, LATE
  reason        String    @db.Text
  status        String    @default("PENDING") // PENDING, APPROVED, REJECTED
  date          DateTime
  tenantId      String
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId])
}

enum LeadStatus {
  PROSPECT
  ACTIVE
  PASSIVE
  BLACKLISTED
  VIP
  CHURN_ALARM
  NEW
  CONTACTED
  HOT
}

enum InteractionType {
  OPEN
  CLICK
  WEBSITE_VISIT
  FORM_SUBMIT
  CALL
  MEETING
  NOTE
  SYSTEM
  CREATED
  PROFILE_PHONE
  PROFILE_WEB
}

model Lead {
  id           String         @id @default(cuid())
  name         String?
  companyName  String?
  email        String?
  phone        String?
  website      String?
  source       String         // MERCAN_WEBSITE, GOOGLE_PLACES etc.
  message      String?        @db.Text
  status       LeadStatus     @default(PROSPECT)
  score        Int            @default(0)
  interactionScore Int        @default(0)
  lastActivityAt DateTime?

  // Bilsoft Integration
  erpId        String?        @unique
  erpCode      String?

  // Google Places Integration
  placeId      String?        @unique  // Google Places unique ID

  // KVKK & Compliance
  communicationOptIn Boolean  @default(true)

  // Advanced CRM Data
  googleRating       Float?     @default(0)
  userRatingsTotal   Int?       @default(0)
  city               String?
  district           String?
  tags               String[]   @default([])
  lastInteractionDate DateTime  @default(now())

  tenantId     String?
  activities   LeadActivity[]
  interactions LeadInteraction[]
  interactionSummaries Interaction[]
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([tenantId])
  @@index([placeId])
}

model LeadInteraction {
  id        String          @id @default(cuid())
  leadId    String
  lead      Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      InteractionType
  metadata  Json?
  createdAt DateTime        @default(now())
}

model Interaction {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        String   // OPEN, CLICK, CREATED, PROFILE_COMPLETION etc.
  scoreAdded  Int      @default(0)
  description String?  @db.Text
  count       Int      @default(0)
  lastSeen    DateTime @default(now())
}

model LeadActivity {
  id          String    @id @default(cuid())
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id])
  type        String // NOTE, CALL, EMAIL_SENT, STATUS_CHANGE
  description String    @db.Text
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  tenantId    String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId])
}

enum JobStatus {
  ACTIVE
  DRAFT
  CLOSED
}

model JobPosting {
  id          String      @id @default(cuid())
  title       String
  description String      @db.Text
  status      JobStatus   @default(DRAFT)
  tenantId    String
  candidates  Candidate[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([tenantId])
}

enum CandidateStatus {
  NEW
  REVIEW
  INTERVIEW
  REJECTED
  HIRED
}

model Candidate {
  id           String          @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  phone        String?
  communicationOptIn Boolean      @default(true)
  cvUrl        String?
  status       CandidateStatus @default(NEW)
  appliedForId String
  jobPosting   JobPosting      @relation(fields: [appliedForId], references: [id])
  tenantId     String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([tenantId])
}

enum LeaveType {
  ANNUAL
  SICK
  EXCUSE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveRequest {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  startDate DateTime
  endDate   DateTime
  type      LeaveType
  status    LeaveStatus @default(PENDING)
  tenantId  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([tenantId])
}

model ApiUsage {
  id        String   @id @default(cuid())
  service   String   // Örn: "GOOGLE_PLACES", "RESEND"
  endpoint  String   // Örn: "AUTOCOMPLETE", "SEND_EMAIL"
  cost      Float    // Tahmini dolar maliyeti (Örn: 0.017)
  createdAt DateTime @default(now())
}

model NetgsmConfig {
  id              String    @id @default(cuid())
  tenantId        String    @unique @default("teknikel") // Proje bazlı tek satır ayar için
  packageStartDate DateTime?
  packageEndDate   DateTime?
  lastTopupDate    DateTime?
  lastTopupAmount  Int?
  senderNames      String[]  // Örn: ["TEKNIKELKMB"]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model BilsoftConfig {
  id              String    @id @default(cuid())
  tenantId        String    @unique @default("teknikel")
  apiUser         String?
  apiPassword     String?
  year            String?
  user            String?
  password        String?
  branch          String?
  taxNumber       String?
  dbName          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ApiToken {
  id           String   @id @default(cuid())
  provider     String   @unique // 'ideasoft', 'bilsoft', 'netgsm' vb.
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}
model ServiceAccount {
   id           String   @id @default(cuid())
   name         String
   serviceToken String   @unique
   tenantId     String
   role         String   @default("BOT")
   createdAt    DateTime @default(now())

   @@index([tenantId])
}

model IyzicoPayment {
   id                        String   @id @default(cuid())
   orderReferenceCode        String   @unique
   customerReferenceCode     String
   subscriptionReferenceCode String?
   iyziReferenceCode         String
   iyziEventType             String
   iyziEventTime             BigInt
   eventDate                 DateTime?
   status                    String   @default("unknown")
   paymentDetails            Json?
   customerDetails           Json?
   orderDetails              Json?
   refund                    Json?
   rawWebhookData            Json?
   logs                      Json     @default("[]")
   processed                 Boolean  @default(false)
   processedAt               DateTime?
   errorHasError             Boolean  @default(false)
   errorMessage              String?
   errorAt                   DateTime?
   createdAt                 DateTime @default(now())
   updatedAt                 DateTime @updatedAt

   @@index([orderReferenceCode])
   @@index([customerReferenceCode])
   @@index([iyziReferenceCode])
   @@index([createdAt])
}

model SmsRecord {
  id              String   @id @default(cuid())
  recipient       String
  message         String
  type            String   @default("manual") // manual, order, notification, reminder, other
  status          String   @default("pending") // pending, sent, failed
  messageId       String?
  bulkId          String?
  jobId           String?
  responseCode    String?
  responseMessage String?
  errorDetail     String?
  orderId         String?
  orderEvent      String?  // create, update, unknown
  orderInfo       Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([createdAt])
  @@index([type])
  @@index([status])
  @@index([recipient])
}

model BilsoftCariCache {
  id              String    @id @default(cuid())
  cariId          Int       @unique
  cariKod         String?
  faturaUnvan     String
  yetkili         String?
  cep             String?
  tel             String?
  mail            String?
  grup            String?
  lastInvoiceDate DateTime?
  lastCheckedAt   DateTime  @default(now())
  tenantId        String    @default("teknikel")

  @@index([tenantId])
}
